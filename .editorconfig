# EditorConfig — pins the whitespace conventions the CI "Format check" job
# enforces (dotnet format whitespace --verify-no-changes). Keep in sync with
# .github/workflows/ci.yml.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,json}]
indent_size = 2

[*.tsv]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
